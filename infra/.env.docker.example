# Copy to .env.docker and fill in.
# docker compose reads this file via --env-file or symlink.

HELIX_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=replace-with-32-byte-secret
ENCRYPTION_KEY=replace-with-fernet-key

POSTGRES_USER=helix
POSTGRES_PASSWORD=helix
POSTGRES_DB=helix
DATABASE_URL=postgresql+asyncpg://helix:helix@postgres:5432/helix

REDIS_URL=redis://redis:6379/0

S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=helix-assets
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

REPLICATE_API_TOKEN=
RUNWAY_API_KEY=
GOOGLE_VEO_API_KEY=

VERCEL_TOKEN=
VERCEL_TEAM_ID=
GITHUB_TOKEN=
GITHUB_ORG=

CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

BRAVE_API_KEY=

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001

API_HOST=0.0.0.0
API_PORT=8000
API_PUBLIC_URL=http://localhost:8000
WEB_PUBLIC_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
