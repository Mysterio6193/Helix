# ============================================================
# Helix environment template
# Copy to infra/.env.docker and fill in.
# ============================================================

# --- Core ---
HELIX_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production-32-bytes-min
ENCRYPTION_KEY=fernet-key-32-urlsafe-base64-bytes

# --- Database ---
POSTGRES_USER=helix
POSTGRES_PASSWORD=helix
POSTGRES_DB=helix
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://helix:helix@postgres:5432/helix

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Storage (S3 / MinIO) ---
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=helix-assets
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# --- LLM providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# --- Image / video providers ---
REPLICATE_API_TOKEN=
RUNWAY_API_KEY=
GOOGLE_VEO_API_KEY=

# --- Deployment + dev tools ---
VERCEL_TOKEN=
VERCEL_TEAM_ID=
GITHUB_TOKEN=
GITHUB_ORG=

# --- Productivity integrations (OAuth client creds) ---
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Search ---
BRAVE_API_KEY=

# --- Observability ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3001

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_PUBLIC_URL=http://localhost:8000
WEB_PUBLIC_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# --- Frontend (Next.js public vars) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
