# ============================================================
# Helix PRODUCTION environment template
# ============================================================
# 1. Copy to .env.production (never commit this file)
# 2. Replace EVERY placeholder marked __REPLACE__
# 3. Use a real Postgres database, real Redis, real S3
# 4. Set HELIX_ENV=production so assert_production_safe() runs
# ============================================================

HELIX_ENV=production
LOG_LEVEL=INFO

# --- Secrets ---
# Regenerate per-deployment. NEVER reuse across environments.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=EGRntKtBjAn2TcuNeq1v8nYd7LdLGT5TJoHCUEvdw8O1KnvJLPZQGPrvzulXSsyM
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=PgPImsSUfbTg7aaw3O6Nrku-UoJZXhCZq2Yp4jWz-OI=

# --- Database (managed Postgres with pgvector) ---
# Fly.io: fly postgres create + flyctl postgres attach
# Render/Railway: provision managed PG, then enable pgvector extension
# Supabase/Neon: enable pgvector under Database -> Extensions
DATABASE_URL=postgresql+asyncpg://__USER__:__PASSWORD__@__HOST__:5432/helix

# --- Redis (managed) ---
# Upstash, Redis Cloud, Fly Redis, etc.
REDIS_URL=rediss://default:__PASSWORD__@__HOST__:6379/0

# --- Storage (S3 or compatible) ---
# Cloudflare R2 example. AWS S3, Backblaze B2, Wasabi also work.
S3_ENDPOINT=https://__ACCOUNT__.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=helix-assets
S3_ACCESS_KEY=__REPLACE__
S3_SECRET_KEY=__REPLACE__

# --- LLM providers ---
OPENAI_API_KEY=__REPLACE__
ANTHROPIC_API_KEY=__REPLACE__
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# --- Image / video providers ---
REPLICATE_API_TOKEN=
RUNWAY_API_KEY=

# --- Google OAuth ---
# console.cloud.google.com -> OAuth 2.0 Client IDs
# Authorized redirect URI: https://app.yourdomain.com/api/proxy/auth/google/callback
GOOGLE_CLIENT_ID=__REPLACE__
GOOGLE_CLIENT_SECRET=__REPLACE__

# --- Stripe billing ---
# Use LIVE keys in production, TEST keys in staging
STRIPE_SECRET_KEY=sk_live___REPLACE__
STRIPE_PUBLISHABLE_KEY=pk_live___REPLACE__
# From dashboard.stripe.com -> Developers -> Webhooks -> reveal signing secret
STRIPE_WEBHOOK_SECRET=whsec___REPLACE__
# From dashboard.stripe.com -> Products. Recurring prices only.
STRIPE_PRICE_STARTER=price___REPLACE__
STRIPE_PRICE_PRO=price___REPLACE__
STRIPE_PRICE_BUSINESS=price___REPLACE__

# --- Productivity integrations (optional, only if you offer them) ---
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
VERCEL_TOKEN=
GITHUB_TOKEN=

# --- Search ---
BRAVE_API_KEY=

# --- Observability ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Public URLs (MUST be https in production) ---
API_PUBLIC_URL=https://api.yourdomain.com
WEB_PUBLIC_URL=https://app.yourdomain.com
CORS_ORIGINS=https://app.yourdomain.com

# --- Frontend (Next.js public vars) ---
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live___REPLACE__

# --- API tuning ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Worker pool ---
WORKER_CONCURRENCY=16
WORKER_MAX_RETRIES=5
